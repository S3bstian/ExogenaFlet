# Entornos virtuales (dependencias locales, no el código)
.venv/
venv/
env/
.env/
.python-version

# Variables y secretos (nunca subir credenciales ni tokens)
.env
.env.*
!.env.example
*.pem
secrets/

# Bytecode y cachés de Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
pip-wheel-metadata/

# Herramientas / tests
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/
.nox/

# PyInstaller / empaquetado
build/
dist/
installer_output/
*.manifest

# Logs y temporales
*.log
*.tmp
*.temp

# IDEs y editores (ajustes personales; si el equipo comparte .vscode, quita la línea)
.idea/
*.swp
*.swo

# SO
Thumbs.db
Desktop.ini
.DS_Store
